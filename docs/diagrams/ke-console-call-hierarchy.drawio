          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- KeConDevPutChar → TryProcessAnsiSeq (dashed side call) -->
        <mxCell id="e4" value="控制字符" style="dashed=1;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=open;endFill=0;fontFamily=Inter, 等线;" edge="1" source="n_putchar" target="n_ansi" parent="1">
