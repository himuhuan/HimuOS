        <mxCell id="zone1_bg" value="" style="rounded=0;fillColor=#dae8fc;strokeColor=#82b3db;opacity=40;" parent="1" vertex="1">
          <mxGeometry x="10" y="55" width="1149" height="165" as="geometry" />
        </mxCell>
        <mxCell id="zone1_lbl" value="第一层：公共 API 层" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#006EAF;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="20" y="58" width="180" height="22" as="geometry" />
        </mxCell>

        <!-- Zone 2: Console Device Layer -->
        <mxCell id="zone2_bg" value="" style="rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;opacity=40;" parent="1" vertex="1">
          <mxGeometry x="10" y="230" width="1149" height="215" as="geometry" />
        </mxCell>
        <mxCell id="zone2_lbl" value="第二层：控制台设备层（KE_CONSOLE_DEVICE）" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#2d7600;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="20" y="233" width="340" height="22" as="geometry" />
        </mxCell>

        <!-- Zone 3: Hardware Sink Layer -->
        <mxCell id="zone3_bg" value="" style="rounded=0;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=40;" parent="1" vertex="1">
          <mxGeometry x="10" y="455" width="1149" height="440" as="geometry" />
        </mxCell>
        <mxCell id="zone3_lbl" value="第三层：硬件接收层（KE_CONSOLE_SINK 虚函数表）" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#b46504;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="20" y="458" width="360" height="22" as="geometry" />
        </mxCell>

        <!-- ====== TIER 1: PUBLIC API ====== -->

        <mxCell id="n_klog" value="&lt;b&gt;KLogWriteFmt()&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ke/log/log.c&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="80" y="88" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_conwrite" value="&lt;b&gt;ConsoleWrite() / ConsoleWriteFmt()&lt;br/&gt;ConsoleWriteChar()&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ke/console/console.c&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="380" y="80" width="260" height="75" as="geometry" />
        </mxCell>

        <mxCell id="n_cs_note" value="&lt;b&gt;KE_CRITICAL_SECTION&lt;/b&gt;&lt;br/&gt;序列化保护（可重入）&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;IRQL 升至 DISPATCH_LEVEL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;fontSize=11;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="750" y="78" width="220" height="78" as="geometry" />
        </mxCell>

        <!-- ====== TIER 2: CONSOLE DEVICE ====== -->

        <mxCell id="n_unlocked" value="&lt;b&gt;ConsoleWriteUnlocked()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#67AB9F;fontColor=#ffffff;strokeColor=#3D7A6E;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="380" y="265" width="260" height="50" as="geometry" />
        </mxCell>

        <mxCell id="n_putchar" value="&lt;b&gt;KeConDevPutChar()&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;光标追踪 / 自动换行 / 越界滚屏&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#67AB9F;fontColor=#ffffff;strokeColor=#3D7A6E;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="380" y="350" width="260" height="65" as="geometry" />
        </mxCell>

        <mxCell id="n_ansi" value="&lt;b&gt;TryProcessAnsiSeq()&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ANSI 转义序列解析&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="750" y="358" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- ====== TIER 3: HARDWARE SINKS ====== -->

        <mxCell id="n_vtable" value="&lt;b&gt;sink-&gt;PutChar(sink, x, y, c, fg, bg)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;KE_CONSOLE_SINK 虚函数表分发&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6821E;fontColor=#ffffff;strokeColor=#B46504;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="380" y="490" width="260" height="65" as="geometry" />
        </mxCell>

        <mxCell id="n_release_note" value="&lt;i&gt;Release build:&lt;br/&gt;直接使用 GFX_CONSOLE_SINK&lt;br/&gt;（跳过 MUX）&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;dashed=1;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="720" y="498" width="200" height="58" as="geometry" />
