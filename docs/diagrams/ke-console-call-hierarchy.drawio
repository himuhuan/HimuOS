        <!-- MUX → Serial (right branch, L-shaped) -->
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_mux" target="n_serial_sink" parent="1">
