        <!-- Serial Sink → COM1 (straight down) -->
        <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_serial_sink" target="n_com1" parent="1">
