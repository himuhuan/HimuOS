        <mxCell id="n_mux" value="&lt;b&gt;MUX_CONSOLE_SINK&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Debug 构建：多路广播&lt;br/&gt;（最多 MAX_MUX_SINKS = 3 个子接收器）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#B46504;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="380" y="600" width="260" height="75" as="geometry" />
        </mxCell>

        <mxCell id="n_gfx" value="&lt;b&gt;GFX_CONSOLE_SINK&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;VdRenderPixel() / VdEfiMethods&lt;br/&gt;drivers/video/video_driver.c&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b85450;fontColor=#ffffff;strokeColor=#6c3b3b;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="160" y="720" width="240" height="75" as="geometry" />
        </mxCell>

        <mxCell id="n_serial_sink" value="&lt;b&gt;SERIAL_CONSOLE_SINK&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SerialWriteByte() / outb()&lt;br/&gt;drivers/serial/serial.c&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b85450;fontColor=#ffffff;strokeColor=#6c3b3b;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="740" y="720" width="240" height="75" as="geometry" />
        </mxCell>

        <mxCell id="n_fb" value="&lt;b&gt;EFI GOP 线性帧缓冲&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MMIO_BASE_VA 映射&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#36393d;fontColor=#ffffff;strokeColor=#14191d;size=10;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="170" y="830" width="220" height="65" as="geometry" />
        </mxCell>

        <mxCell id="n_com1" value="&lt;b&gt;COM1 I/O 端口（0x3F8）&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;x86 outb 指令&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#36393d;fontColor=#ffffff;strokeColor=#14191d;size=10;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="750" y="830" width="220" height="65" as="geometry" />
