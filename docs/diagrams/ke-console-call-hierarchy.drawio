        <mxCell id="e_cs" value="" style="dashed=1;endArrow=none;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n_cs_note" target="n_conwrite" parent="1">
