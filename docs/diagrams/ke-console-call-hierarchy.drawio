        <!-- MUX → GFX (left branch, L-shaped) -->
        <mxCell id="e8" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_mux" target="n_gfx" parent="1">
