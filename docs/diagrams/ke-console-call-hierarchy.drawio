        <!-- KeConDevPutChar → vtable dispatch (down, crosses zone boundary) -->
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_putchar" target="n_vtable" parent="1">
