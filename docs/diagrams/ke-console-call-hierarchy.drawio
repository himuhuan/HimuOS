<mxfile host="Electron" version="28.1.2">
  <diagram name="KE 层三层调用架构" id="ke-console-hierarchy">
    <mxGraphModel adaptiveColors="auto" dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="KE 层三层调用架构 — 控制台子系统示例" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontFamily=Inter, 等线;" parent="1" vertex="1">
          <mxGeometry x="280" y="10" width="600" height="35" as="geometry" />
        </mxCell>

        <!-- ====== ZONE BACKGROUNDS ====== -->

